# RHD Decision Thresholds (ISBT Standards)
IDENTITY_RHD_POSITIVE = 90.0  # % - identity threshold for valid RHD
IDENTITY_VERY_HIGH = 95.0  # % - threshold for standard RhD+ (no SNPs)

# ISBT-Defined Diagnostic SNP Positions (cDNA positions)
